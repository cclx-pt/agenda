{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "server/serverless.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "server/serverless.js" },
    { "src": "/auth/(.*)", "dest": "server/serverless.js" },
    { "src": "/data/(.*)", "dest": "server/serverless.js" },
    { "src": "/health(.*)", "dest": "server/serverless.js" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "crons": [
    { "path": "/data/integration/sync/cron", "schedule": "0 * * * *" }
  ]
}
