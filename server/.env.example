# ===== Servidor =====
# Porta de escuta. Em produção na Hostinger (Node.js Web App) a porta é
# injetada automaticamente em PORT — não é preciso defini-la no painel.
PORT=4000
# Origem do front-end. Em dev é o Vite (5173). Em produção, como o backend
# serve também o frontend (mesma origem), usa o domínio público do site.
CORS_ORIGIN=http://localhost:5173
# development | production. Na Hostinger define NODE_ENV=production (ativa
# cookies "secure", trust proxy e o proxy /api -> inRadar).
NODE_ENV=development
# (Opcional) Caminho do build do frontend que o backend serve. Por omissão é
# a pasta dist/ na raiz do repositório; só é preciso se mudares a estrutura.
# CLIENT_DIST=../dist

# ===== Base de dados (MySQL / MariaDB) =====
# String de ligação completa. Na Hostinger usa os dados do painel (MySQL):
#   mysql://UTILIZADOR:SENHA@HOST:3306/NOME_DA_BASE
# Em dev, com MySQL/MariaDB local:
DATABASE_URL=mysql://cclx:cclx@localhost:3306/cclx_agenda
# TLS para a ligação à BD. Na Hostinger, com BD no mesmo alojamento, normalmente false.
DB_SSL=false
# (Opcional) Tamanho máximo do pool de ligações.
DB_POOL_SIZE=10

# ===== Sessão (JWT) =====
# Gera um segredo forte: `node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"`
JWT_SECRET=troca-isto-por-um-segredo-forte
# Duração da sessão (em horas)
SESSION_HOURS=8
# Pepper para o hash dos códigos OTP (qualquer string longa e secreta)
OTP_PEPPER=troca-isto-tambem

# ===== OTP =====
# Validade do código em minutos
OTP_TTL_MINUTES=10
# Tentativas máximas por código antes de invalidar
OTP_MAX_ATTEMPTS=5
# Código mestre para testes locais — ACEITA SEMPRE este código no login.
# Ignorado quando NODE_ENV=production. Deixa vazio/ausente para desativar.
DEV_MASTER_OTP=

# ===== Email (SMTP via nodemailer) =====
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Agenda CCLX <agenda@cclx.pt>"

# ===== Seed do administrador inicial =====
SEED_ADMIN_EMAIL=admin@cclx.pt
SEED_ADMIN_NAME=Administrador CCLX

# ===== API inChurch / inRadar (leitura da agenda) =====
# Em producao o backend faz o proxy de /api -> inRadar (o Vite nao existe no VPS).
INRADAR_BASE_URL=https://inradar.com.br/public/v1
INCHURCH_API_KEY=
INCHURCH_API_SECRET=
INCHURCH_API_VERSION=v1
