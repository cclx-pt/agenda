# ===== Servidor =====
# Porta de escuta (apenas em local/standalone). No Vercel a app corre como
# função serverless e a porta é gerida pela plataforma — não é preciso definir.
PORT=4000
# Origem do front-end (CORS). Em dev é o Vite (5173). No Vercel, como o frontend
# e a API partilham o mesmo domínio (same-origin), usa o domínio público:
#   https://<projeto>.vercel.app  (ou o domínio personalizado)
CORS_ORIGIN=http://localhost:5173
# development | production. No Vercel é definido automaticamente como
# "production" (ativa cookies "secure", trust proxy e o proxy /api -> inRadar).
NODE_ENV=development
# (Opcional) Caminho do build do frontend servido em local/standalone. Por
# omissão é a pasta dist/ na raiz; no Vercel o dist/ é servido pela CDN.
# CLIENT_DIST=../dist

# ===== Base de dados (Supabase / PostgreSQL) =====
# String de ligação ao Supabase (Postgres). EM SERVERLESS (Vercel) usa o pooler
# "Supavisor" em modo TRANSAÇÃO (porta 6543), pensado para muitas ligações
# curtas. Copia-o em Supabase → Project Settings → Database → Connection string
# → "Transaction pooler":
#   postgresql://postgres.<ref>:SENHA@aws-0-<regiao>.pooler.supabase.com:6543/postgres
# Em local/standalone (1 processo) pode usar-se o modo sessão (porta 5432).
DATABASE_URL=postgresql://postgres.xxxxxxxx:SENHA@aws-0-eu-west-1.pooler.supabase.com:6543/postgres
# TLS para a ligação à BD. No Supabase é OBRIGATÓRIO — deixa ligado (qualquer
# valor != "false"). Define DB_SSL=false apenas para um Postgres local sem TLS.
DB_SSL=true
# Tamanho máximo do pool POR INSTÂNCIA. Em serverless mantém-no a 1 (cada
# função trata um pedido de cada vez); em local/standalone podes subir (ex.: 10).
DB_POOL_SIZE=1

# ===== Supabase Storage (imagens de eventos) =====
# URL do projeto Supabase (Supabase → Project Settings → API → Project URL):
#   https://<ref>.supabase.co
SUPABASE_URL=https://xxxxxxxx.supabase.co
# Service role key (Supabase → Project Settings → API → service_role).
# SEGREDO — usado SÓ no backend, NUNCA no frontend.
SUPABASE_SERVICE_ROLE_KEY=
# Nome do bucket (público) onde as imagens são guardadas. Cria-o no Supabase
# → Storage e marca-o como "Public bucket".
SUPABASE_STORAGE_BUCKET=event-images

# ===== Sessão (JWT) =====
# Gera um segredo forte: `node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"`
JWT_SECRET=troca-isto-por-um-segredo-forte
# Duração da sessão (em horas)
SESSION_HOURS=8
# Pepper para o hash dos códigos OTP (qualquer string longa e secreta)
OTP_PEPPER=troca-isto-tambem

# ===== OTP =====
# Validade do código em minutos
OTP_TTL_MINUTES=10
# Tentativas máximas por código antes de invalidar
OTP_MAX_ATTEMPTS=5
# Código mestre para testes locais — ACEITA SEMPRE este código no login.
# Ignorado quando NODE_ENV=production. Deixa vazio/ausente para desativar.
DEV_MASTER_OTP=

# ===== Email (SMTP via nodemailer) =====
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Agenda CCLX <agenda@cclx.pt>"

# ===== Seed do administrador inicial =====
SEED_ADMIN_EMAIL=admin@cclx.pt
SEED_ADMIN_NAME=Administrador CCLX

# ===== API inChurch / inRadar (leitura da agenda) =====
# Em producao o backend faz o proxy de /api -> inRadar (o Vite nao existe no VPS).
INRADAR_BASE_URL=https://inradar.com.br/public/v1
INCHURCH_API_KEY=
INCHURCH_API_SECRET=
INCHURCH_API_VERSION=v1
